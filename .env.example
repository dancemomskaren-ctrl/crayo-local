# DeepSeek API Configuration (for script generation)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com

# Optional: OpenAI-compatible API for script generation
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_API_BASE=https://api.openai.com

# Platform Posting API Keys (optional — enables one-click posting)
# Instagram Graph API
# INSTAGRAM_ACCESS_TOKEN=your_instagram_token_here
# INSTAGRAM_ACCOUNT_ID=your_account_id_here

# TikTok API
# TIKTOK_ACCESS_TOKEN=your_tiktok_token_here

# YouTube Data API
# YOUTUBE_API_KEY=your_youtube_api_key_here
# YOUTUBE_CHANNEL_ID=your_channel_id_here
